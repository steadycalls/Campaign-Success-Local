# GHL Agency — used only to list sub-accounts
GHL_AGENCY_PIT=
GHL_COMPANY_ID=

# Individual sub-account PITs are stored in the database,
# managed via Settings > Sub-Accounts tab

# Teamwork
TEAMWORK_API_KEY=
TEAMWORK_SITE=

# Read.ai
READAI_API_KEY=

# Google Drive (OAuth 2.0 for Desktop)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DRIVE_CLIENT_FOLDER_ID=

# Restoration Inbound — client contact priority sync
RI_LOCATION_ID=g6zCuamu3IQlnY1ympGx

# SLA thresholds
SLA_WARNING_DAYS=5
SLA_VIOLATION_DAYS=7

# Sync schedule (cron expression)
SYNC_CRON=0 */4 * * *

# Cloud Sync (Cloudflare D1 mirror)
CLOUD_SYNC_ENABLED=false
CLOUD_SYNC_WORKER_URL=
CLOUD_SYNC_API_KEY=
