{
  "name": "li-client-ops-hub",
  "version": "0.1.0",
  "description": "Local Electron desktop app for Logic Inbound client operations",
  "main": "electron-dist/electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsc -w -p tsconfig.electron.json\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development node scripts/launch-electron.js\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "package": "npm run build && electron-builder --win",
    "start": "node scripts/launch-electron.js"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "electron-is-dev": "^3.0.0",
    "lucide-react": "^0.383.0",
    "node-cron": "^3.0.0",
    "open": "^11.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.26.0",
    "sql.js": "^1.11.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "cross-env": "^10.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "wait-on": "^8.0.0"
  }
}
